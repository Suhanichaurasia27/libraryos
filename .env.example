# ─────────────────────────────────────────────────────────────────
#  LibraryOS – Environment Variables Template
#
#  HOW TO USE:
#  1. Copy this file:  copy .env.example .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env to GitHub — it's in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Security ───────────────────────────────────────────────────────
# Change this to a long random string in production!
# Generate one at: https://randomkeygen.com
JWT_SECRET=change-this-to-a-long-random-secret-string

# ── Email (Gmail) ──────────────────────────────────────────────────
# Step 1: Enable 2-Factor Authentication on your Gmail
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail"
# Step 4: Paste the 16-character App Password below (NOT your real Gmail password)
GMAIL_USER=yourlibrary@gmail.com
GMAIL_PASS=your_16_char_app_password_here
