# ─────────────────────────────────────────────────────────────────
#  LibraryOS – .gitignore
#  Everything listed here will NOT be uploaded to GitHub
# ─────────────────────────────────────────────────────────────────

# ── Secrets & Config ───────────────────────────────────────────────
.env                    # Your real keys — NEVER upload this

# ── Database ───────────────────────────────────────────────────────
*.db                    # SQLite database contains real user data
*.db-shm
*.db-wal

# ── Node.js ────────────────────────────────────────────────────────
node_modules/           # Installed packages (too large, auto-installed)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ───────────────────────────────────────────────────────
.DS_Store               # macOS
Thumbs.db               # Windows
desktop.ini

# ── Editor Files ───────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Logs ───────────────────────────────────────────────────────────
logs/
*.log
